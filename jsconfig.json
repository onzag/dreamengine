{
  "compilerOptions": {
    "module": "esnext",
    "checkJs": true,
    "strict": true,
    "moduleResolution": "node",
    "target": "es2020",
    "moduleDetection": "force",
    "ignoreDeprecations": "6.0"
  },
  "typeAcquisition": {"enable": false},
  "include": ["js/**/*.js", "js/types/**/*.d.ts"],
  "exclude": ["node_modules", "prototype"]
}